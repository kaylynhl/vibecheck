# Backend (Python) secrets.
# Copy to `.env`, fill in your own values, never commit.

# Required: Groq vision API key for the LLM-based image -> tag pipeline.
GROQ_API_KEY=

# Required for Step 5 (music recommendations): Spotify Web API Client
# Credentials. Create an app at https://developer.spotify.com/dashboard.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Optional. Comma-separated allowlist of origins for CORS. Default "*".
# Lock this down before deploying anywhere public.
# VIBECHECK_CORS_ORIGINS=https://your-app.example.com

# Optional. Override uvicorn bind host/port and reload behaviour. Defaults
# are 0.0.0.0:8000 with reload=true (set RELOAD=0 to disable).
# VIBECHECK_HOST=0.0.0.0
# VIBECHECK_PORT=8000
# VIBECHECK_RELOAD=1
