# vibecheck .gitignore

# --- OS / editor ---
.DS_Store
Thumbs.db
.vscode/
.idea/

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg-info/
dist/
build/
.pytest_cache/
.coverage
.ruff_cache/
.mypy_cache/

# --- Environments / secrets ---
.venv/
venv/
.env
.env.*
!.env.example
!**/.env.example
*.pem
*.key

# --- Notebooks ---
.ipynb_checkpoints/

# --- Data / outputs (do not commit) ---
data/raw/
data/processed/
outputs/
runs/
wandb/
logs/

# --- Models / artifacts ---
checkpoints/
models/
*.pt
*.pth
*.onnx

# --- Audio ---
*.wav
*.mp3
*.flac
*.m4a

# --- Archives ---
*.zip
*.tar.gz

# --- Personal scratch (not part of the submitted project) ---
notes.md
notes/
TODO.md
scratch/
PLAN.md
HANDOFF.md

# --- raw files ---
data/clothing_raw/
data/rooms_raw/
data/eval/outfits
data/eval/rooms
dataset_compiled/
spotify/spotify_data.csv 
reddit/fashion-bert-output-v4

# --- notebook / report artifacts ---
plots_for_report/
notebooks/artifacts/

# --- repo-root noise ---
/package-lock.json