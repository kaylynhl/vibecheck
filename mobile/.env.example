# Mobile (Expo) build-time config.
# Copy to `.env`, set values, never commit.
# Vars MUST be prefixed with `EXPO_PUBLIC_` to be readable from the JS bundle.

# Backend base URL the app POSTs to.
#   iOS simulator:  http://localhost:8000
#   Real iPhone:    http://<your-laptop-LAN-ip>:8000  (printed by `make serve`)
#   Cloud:          https://your-api.example.com
EXPO_PUBLIC_API_URL=http://localhost:8000

# Set to "1" to force the offline mock pipeline (useful for UI work
# when the backend is down).
EXPO_PUBLIC_USE_MOCK=
